generator client {
  provider = "prisma-client-js"
  previewFeatures = ["strictUndefinedChecks"] // https://www.prisma.io/docs/orm/prisma-client/special-fields-and-types/null-and-undefined
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int    @id @default(autoincrement())
  username      String @unique
  email         String @unique
  password_hash String
  sessions      Session[]
}

model Session {
  id        String   @id
  userId    Int
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
