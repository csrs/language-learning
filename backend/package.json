{
  "name": "my-app_backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "npx eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx src/server.ts",
    "openapi:generate": "tsx src/scripts/openapi/generateOpenApiDocument.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "dev:docker": "tsx watch src/server.ts",
    "ankiToDatabase": "tsx src/scripts/database/ankiToDatabase.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.6.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.1.0"
  }
}
